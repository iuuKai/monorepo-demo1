{
	"version": 2,
	"builds": [
		{
			"src": "project-A/app.js",
			"use": "@vercel/node"
		},
		{
			"src": "project-B/app.js",
			"use": "@vercel/node"
		}
	],
	"rewrites": [
		{
			"source": "/project-A/",
			"destination": "/project-A/app.js"
		},
		{
			"source": "/project-A/:path*",
			"destination": "/project-A/app.js"
		},
		{
			"source": "/project-B/",
			"destination": "/project-B/app.js"
		},
		{
			"source": "/project-B/:path*",
			"destination": "/project-B/app.js"
		}
	]
}
